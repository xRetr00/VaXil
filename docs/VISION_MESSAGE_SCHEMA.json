{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/schemas/vision.snapshot.json",
  "title": "JARVIS Vision Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "version",
    "ts",
    "node_id",
    "objects",
    "gestures",
    "summary"
  ],
  "properties": {
    "type": {
      "const": "vision.snapshot"
    },
    "version": {
      "const": "1.0"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string"
    },
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "objects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "class",
          "confidence"
        ],
        "properties": {
          "class": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          }
        }
      }
    },
    "gestures": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "confidence"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          }
        }
      }
    },
    "summary": {
      "type": "string"
    }
  }
}
